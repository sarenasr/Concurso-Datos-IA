# Socrata / datos.gov.co
SOCRATA_APP_TOKEN=
SOCRATA_DOMAIN=www.datos.gov.co

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# LLM via LiteLLM (provider-agnostic). OpenCode endpoints are OpenAI-compatible.
LITELLM_MODEL=gpt-4.1-mini
LITELLM_API_BASE=
LITELLM_API_KEY=
# Fallback direct provider for demo laptop
OPENAI_API_KEY=

# Embeddings (Gemini free tier)
GEMINI_API_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=

# Misc
LOG_LEVEL=INFO
