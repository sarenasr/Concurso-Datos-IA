# Manglar backend environment
# Copy to .env and fill in.

# --- Socrata / datos.gov.co ---
SOCRATA_APP_TOKEN=
SOCRATA_DOMAIN=www.datos.gov.co

# --- Supabase (pgvector catalog) ---
SUPABASE_URL=
SUPABASE_SERVICE_KEY=           # service-role key; preferred for server
SUPABASE_SECRET_KEY=            # legacy anon key fallback

# --- LLM (LiteLLM provider-agnostic) ---
LITELLM_MODEL=gpt-4.1-mini      # default model for the agent
LITELLM_SMALL_MODEL=glm-5.2      # hot-path model (triage/SoQL/reranker/join). Prefer a FAST model here; avoid reasoning models like qwen3.7-plus (~2x slower)
LITELLM_API_BASE=               # OpenAI-compatible base URL (e.g. OpenCode Go)
LITELLM_API_KEY=                # API key for the custom base URL

# Direct provider keys (fallbacks when LITELLM_API_BASE is empty)
OPENAI_API_KEY=
OPENROUTER_API_KEY=             # preferred provider for embeddings + LLM

# --- Embeddings (Gemini free tier) ---
GEMINI_API_KEY=                 # single key
GEMINI_API_KEYS=                # comma-separated keys for quota cycling

# --- Telegram ---
TELEGRAM_BOT_TOKEN=

# --- Misc ---
LOG_LEVEL=INFO                  # DEBUG / INFO / WARNING / ERROR
NUMPY_FALLBACK=false            # bool: enable slow in-process NumPy vector fallback
ENABLE_RERANKER=true            # bool: enable LLM-based reranker on search results
# comma-separated, e.g. http://localhost:3000,https://app.example.com
CORS_ORIGINS=http://localhost:3000,https://concurso-datos-ia.vercel.app

# --- LLM latency budget (tune down for faster failover on slow providers) ---
LLM_TIMEOUT_S=15
LLM_MAX_ATTEMPTS=2
LLM_BACKOFF_MAX_S=2
RERANK_TIMEOUT_S=8
RERANK_MAX_CANDIDATES=8

# --- Frontend (apps/frontend) ---
# NEXT_PUBLIC_BACKEND_URL=concurso-datos-ia-production.up.railway.app
