# Manglar backend environment
# Copy to .env and fill in.

# --- Socrata / datos.gov.co ---
SOCRATA_APP_TOKEN=
SOCRATA_DOMAIN=www.datos.gov.co

# --- Supabase (pgvector catalog) ---
SUPABASE_URL=
SUPABASE_SERVICE_KEY=           # service-role key; preferred for server
SUPABASE_SECRET_KEY=            # legacy anon key fallback

# --- LLM (OpenRouter only; use full model slugs) ---
# Pick a model that is FAST *and* produces valid Socrata SoQL. Many cheap
# "flash/nano/lite/small" models emit plain SQL (SELECT...FROM) and BREAK SoQL.
# Verified-good fast picks: anthropic/claude-haiku-4.5 (~1.5s, best),
# google/gemini-3-flash-preview (~1.2s), openai/gpt-4.1-mini (~2s), qwen/qwen3-max.
LITELLM_MODEL=anthropic/claude-sonnet-4.5        # answer model (Spanish prose)
LITELLM_SMALL_MODEL=anthropic/claude-sonnet-4.5  # hot-path (triage/SoQL/join)
LITELLM_API_BASE=               # leave EMPTY for OpenRouter only
LITELLM_API_KEY=                # only needed for a custom OpenAI-compatible base

# Direct provider keys (fallbacks when LITELLM_API_BASE is empty)
OPENAI_API_KEY=
OPENROUTER_API_KEY=             # powers embeddings + LLM completions

# --- Embeddings (Gemini free tier) ---
GEMINI_API_KEY=                 # single key
GEMINI_API_KEYS=                # comma-separated keys for quota cycling

# --- Telegram ---
TELEGRAM_BOT_TOKEN=

# --- Misc ---
LOG_LEVEL=INFO                  # DEBUG / INFO / WARNING / ERROR
NUMPY_FALLBACK=false            # bool: enable slow in-process NumPy vector fallback
# Reranker: hosted cross-encoder (cohere/rerank-4-pro) via OpenRouter, reusing
# OPENROUTER_API_KEY; no separate key needed. Multilingual (Spanish), ~$0.0025/search;
# on by default. Swap RERANK_MODEL for any OpenRouter rerank slug.
ENABLE_RERANKER=true
RERANK_MODEL=cohere/rerank-4-pro
# comma-separated, e.g. http://localhost:3000,https://app.example.com
CORS_ORIGINS=http://localhost:3000,https://concurso-datos-ia.vercel.app

# --- LLM latency budget (tune down for faster failover on slow providers) ---
LLM_TIMEOUT_S=15
LLM_MAX_ATTEMPTS=2
LLM_BACKOFF_MAX_S=2
RERANK_TIMEOUT_S=3               # cross-encoder round-trip; allow network slack
RERANK_MAX_CANDIDATES=20        # cheap cross-encoder call, handles a bigger batch

# --- Frontend (apps/frontend) ---
# NEXT_PUBLIC_BACKEND_URL=concurso-datos-ia-production.up.railway.app
