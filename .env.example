# Socrata / datos.gov.co
SOCRATA_APP_TOKEN=
SOCRATA_DOMAIN=www.datos.gov.co

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# LLM via LiteLLM (OpenRouter for reliability)
OPENROUTER_API_KEY=
LITELLM_MODEL=gpt-4.1-mini
LITELLM_SMALL_MODEL=gpt-4.1-mini
# Fallback: OpenAI-compatible endpoint (e.g. OpenCode Go)
LITELLM_API_BASE=
LITELLM_API_KEY=
# Fallback direct provider for demo laptop
OPENAI_API_KEY=

# Embeddings (Gemini free tier) — currently unused, kept for future use
GEMINI_API_KEY=
GEMINI_API_KEYS=

# Telegram
TELEGRAM_BOT_TOKEN=

# Misc
LOG_LEVEL=INFO

# Frontend: set this to the production backend URL for prod builds
# NEXT_PUBLIC_BACKEND_URL=concurso-datos-ia-production.up.railway.app
